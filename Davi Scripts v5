
local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

-- CONFIG
local ImageID = "rbxassetid://Davi_Scripts"

local Toggles = {
    Farm = false,
    Chest = false
}

local FarmMode = "Melee"

-- GUI
local ScreenGui = Instance.new("ScreenGui", game.CoreGui)

-- BOTÃO REDONDO
local OpenButton = Instance.new("ImageButton")
OpenButton.Parent = ScreenGui
OpenButton.Size = UDim2.new(0,60,0,60)
OpenButton.Position = UDim2.new(0,100,0,100)
OpenButton.Image = ImageID
OpenButton.BackgroundTransparency = 1
OpenButton.Active = true
OpenButton.Draggable = true

-- FRAME
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0,320,0,400)
Frame.Position = UDim2.new(0.3,0,0.2,0)
Frame.BackgroundColor3 = Color3.fromRGB(15,15,15)
Frame.Visible = false
Frame.Active = true
Frame.Draggable = true

Instance.new("UIListLayout", Frame)

OpenButton.MouseButton1Click:Connect(function()
    Frame.Visible = not Frame.Visible
end)

-- BOTÃO
function criarBotao(texto, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = Frame
    btn.Size = UDim2.new(1,0,0,35)
    btn.Text = texto
    btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    btn.TextColor3 = Color3.new(1,1,1)

    btn.MouseButton1Click:Connect(callback)
end

-- EQUIPAR ARMA
function Equipar()
    pcall(function()
        for i,v in pairs(player.Backpack:GetChildren()) do
            if FarmMode == "Melee" and v.ToolTip == "Melee" then
                char.Humanoid:EquipTool(v)
            elseif FarmMode == "Sword" and v.ToolTip == "Sword" then
                char.Humanoid:EquipTool(v)
            elseif FarmMode == "Gun" and v.ToolTip == "Gun" then
                char.Humanoid:EquipTool(v)
            elseif FarmMode == "Fruit" and v.ToolTip == "Blox Fruit" then
                char.Humanoid:EquipTool(v)
            end
        end
    end)
end

-- ATAQUE AUTOMÁTICO
function Attack()
    pcall(function()
        if char:FindFirstChildOfClass("Tool") then
    char:FindFirstChildOfClass("Tool"):Activate()
        end
    end)
end

-- FLY SYSTEM
local Fly = false
local BV, BG

function StartFly()
    pcall(function()
        Fly = true

        if not char:FindFirstChild("HumanoidRootPart") then return end

        BV = Instance.new("BodyVelocity")
        BV.MaxForce = Vector3.new(999999,999999,999999)
        BV.Velocity = Vector3.new(0,0,0)
        BV.Parent = char.HumanoidRootPart

        BG = Instance.new("BodyGyro")
        BG.MaxTorque = Vector3.new(999999,999999,999999)
        BG.CFrame = char.HumanoidRootPart.CFrame
        BG.Parent = char.HumanoidRootPart
    end)
end

function StopFly()
    Fly = false
    if BV then BV:Destroy() end
    if BG then BG:Destroy() end
end
-- AUTO FARM
function AutoFarm()
    while Toggles.Farm do
        task.wait()

        pcall(function()
            local enemiesFolder = workspace:FindFirstChild("Enemies")
            if not enemiesFolder then return end

            for i,v in pairs(enemiesFolder:GetChildren()) do
                if v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
                    
                    repeat task.wait()

                        if not Toggles.Farm then break end

                        Equipar()

                        char.HumanoidRootPart.CFrame =
                            v.HumanoidRootPart.CFrame * CFrame.new(0,20,0)

                        Attack()

                    until v.Humanoid.Health <= 0 or not Toggles.Farm
                end
            end
        end)
    end
end

-- AUTO CHEST OTIMIZADO
function AutoChest()
    while Toggles.Chest do
        task.wait(1)

        pcall(function()
            for i,v in pairs(workspace:GetDescendants()) do
                if string.find(v.Name:lower(),"chest") then
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        char.HumanoidRootPart.CFrame = v.CFrame
                        task.wait(0.3)
                    end
                end
            end
        end)
    end
end

-- BOTÕES
criarBotao("Auto Farm", function()
    Toggles.Farm = not Toggles.Farm
    if Toggles.Farm then task.spawn(AutoFarm) end
end)

criarBotao("Auto Chest", function()
    Toggles.Chest = not Toggles.Chest
    if Toggles.Chest then task.spawn(AutoChest) end
end)

criarBotao("Modo: Melee", function() FarmMode = "Melee" end)
criarBotao("Modo: Fruit", function() FarmMode = "Fruit" end)
criarBotao("Modo: Sword", function() FarmMode = "Sword" end)
criarBotao("Modo: Gun", function() FarmMode = "Gun" end)

criarBotao("Fechar", function()
    ScreenGui:Destroy()
end)
