local function Enemy()
    local root = Char():WaitForChild("HumanoidRootPart")
    local closest,dist = nil,math.huge

    for _,v in pairs(workspace.Enemies:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            local d = (v.HumanoidRootPart.Position-root.Position).Magnitude
            if d < dist then
                closest = v
                dist = d
            end
        end
    end

    return closest
end

local function MoveTo(pos)
    local root = Char():WaitForChild("HumanoidRootPart")
    root.CFrame = root.CFrame:Lerp(CFrame.new(pos), Config.Speed)
end

local function Attack()
    local tool = Char():FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
end

RunService.RenderStepped:Connect(function()

    local root = Char():FindFirstChild("HumanoidRootPart")
    if not root then return end

    if Toggles["Auto Farm Level"] or Toggles["Auto Kaitun"] then
        local e = Enemy()
        if e then
            MoveTo(e.HumanoidRootPart.Position + Vector3.new(0,3,3))
            Attack()
        end
    end

    if Toggles["Auto Chest"] then
        for _,v in pairs(workspace:GetChildren()) do
            if string.find(v.Name,"Chest") then
                MoveTo(v.Position)
            end
        end
    end

    if Toggles["Auto Berry"] then
        for _,v in pairs(workspace:GetChildren()) do
            if string.find(v.Name,"Berry") then
                MoveTo(v.Position)
            end
        end
    end

end)
